{
  "name": "idn-area",
  "version": "7.0.1",
  "description": "API that provides information about Indonesia administrative area.",
  "author": "fityannugroho (https://github.com/fityannugroho)",
  "funding": "https://github.com/sponsors/fityannugroho",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fityannugroho/idn-area"
  },
  "keywords": [
    "idn-area",
    "indonesia",
    "wilayah",
    "area",
    "data",
    "api"
  ],
  "scripts": {
    "build": "nest build",
    "prisma:gen": "tsx prisma/generate.ts",
    "db:migrate": "tsx prisma/migrate.ts",
    "db:seed": "prisma db seed",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky || exit 0",
    "lint:staged": "lint-staged",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage",
    "test:e2e": "vitest run --config ./vitest.config.e2e.mts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/platform-fastify": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "husky": "^9.1.7",
    "idn-area-data": "^4.0.1",
    "lint-staged": "^17.0.5",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "ajv@8": "8.18.0",
      "fastify": "5.8.5",
      "brace-expansion@1.1.12": "1.1.13",
      "brace-expansion@5.0.4": "5.0.5",
      "defu": "6.1.5",
      "fast-uri": "3.1.2",
      "lodash": "4.18.1",
      "picomatch": "4.0.4",
      "postcss": "8.5.10",
      "vite": "7.3.2"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write"
    ],
    "*.json": [
      "biome check --write"
    ]
  }
}
